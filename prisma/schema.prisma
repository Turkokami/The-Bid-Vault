// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ContractStage {
  ACTIVE
  WATCH
  REBID_SOON
  EXPIRED
}

enum PredictionMethod {
  EXPIRATION_DATE
  HISTORICAL_PATTERN
  MANUAL
}

enum AlertRuleType {
  SAVED_CONTRACT
  SAVED_SEARCH
  SIMILAR_CONTRACT
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  passwordHash      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  memberships       TenantMembership[]
  savedContracts    SavedContract[]
  savedStateLocalOpportunities SavedStateLocalOpportunity[]
  savedCategoryCodes UserSavedCategoryCode[]
  alertRules        AlertRule[]
  notifications     Notification[]
}

model Tenant {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    TenantMembership[]
  contracts      Contract[]
  categoryCodes  TenantCategoryCode[]
  alertRules     AlertRule[]
  notifications  Notification[]
}

model TenantMembership {
  id        String         @id @default(cuid())
  userId    String
  tenantId  String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId, role])
}

model Contract {
  id                 String            @id @default(cuid())
  tenantId           String
  title              String
  agency             String
  naicsCode          String
  location           String
  state              String?
  city               String?
  summary            String            @db.Text
  source             String?
  sourceExternalId   String?
  awardAmount        Decimal?          @db.Decimal(14, 2)
  awardDate          DateTime?
  expirationDate     DateTime?
  stage              ContractStage     @default(ACTIVE)
  incumbentCompany   String?
  opportunityScore   Int?
  winProbability     Decimal?          @db.Decimal(5, 2)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  winningBids        WinningBid[]
  savedContracts     SavedContract[]
  rebidPredictions   RebidPrediction[]

  @@unique([tenantId, source, sourceExternalId])
  @@index([tenantId, agency])
  @@index([tenantId, naicsCode])
  @@index([tenantId, location])
  @@index([tenantId, expirationDate])
}

model WinningBid {
  id          String   @id @default(cuid())
  contractId  String
  companyName String
  bidAmount   Decimal? @db.Decimal(14, 2)
  awardDate   DateTime?
  createdAt   DateTime @default(now())
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, awardDate])
}

model SavedContract {
  id                 String   @id @default(cuid())
  userId             String
  contractId         String
  reminderDaysBefore Int      @default(30)
  ownerLabel         String?
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract           Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([userId, contractId])
  @@index([contractId])
}

model RebidPrediction {
  id               String           @id @default(cuid())
  contractId       String
  predictedDate    DateTime
  confidenceScore  Decimal          @db.Decimal(5, 2)
  predictionMethod PredictionMethod
  notes            String?          @db.Text
  calculatedAt     DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  contract         Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, predictedDate])
}

model AlertRule {
  id                 String          @id @default(cuid())
  tenantId           String
  userId             String
  type               AlertRuleType
  label              String
  keywordQuery       String?
  agencyFilter       String?
  naicsCodeFilter    String?
  locationFilter     String?
  reminderDaysBefore Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([userId, type])
}

model Notification {
  id          String              @id @default(cuid())
  tenantId    String
  userId      String
  title       String
  body        String              @db.Text
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(PENDING)
  sendAt      DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId, readAt])
}

model StateLocalOpportunity {
  id                  String   @id @default(cuid())
  sourceName          String
  stateCode           String
  title               String
  issuingEntity       String
  opportunityType     String
  status              String
  categoryCode        String?
  postedDate          DateTime?
  dueDate             DateTime?
  summary             String?  @db.Text
  location            String?
  sourceUrl           String?
  registrationRequired Boolean @default(false)
  registrationNotes   String?  @db.Text
  contactName         String?
  contactEmail        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  savedByUsers        SavedStateLocalOpportunity[]

  @@index([sourceName, stateCode])
  @@index([status, dueDate])
}

model SourceSyncLog {
  id            String   @id @default(cuid())
  sourceName    String
  syncStatus    String
  lastRunAt     DateTime @default(now())
  recordsAdded  Int      @default(0)
  recordsUpdated Int     @default(0)
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([sourceName, lastRunAt])
}

model SavedStateLocalOpportunity {
  id                 String   @id @default(cuid())
  userId             String
  opportunityId      String
  reminderDaysBefore Int      @default(14)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity        StateLocalOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([opportunityId])
}

model CategoryCode {
  id                 String   @id @default(cuid())
  sourceName         String
  code               String
  title              String
  description        String   @db.Text
  parentCode         String?
  topLevelCategory   String
  normalizedKeywords String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  savedByUsers       UserSavedCategoryCode[]
  tenantMappings     TenantCategoryCode[]

  @@unique([sourceName, code])
  @@index([topLevelCategory, title])
  @@index([parentCode])
}

model UserSavedCategoryCode {
  id             String       @id @default(cuid())
  userId         String
  categoryCodeId String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryCode   CategoryCode @relation(fields: [categoryCodeId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryCodeId])
  @@index([categoryCodeId])
}

model TenantCategoryCode {
  id             String       @id @default(cuid())
  tenantId        String
  categoryCodeId String
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryCode   CategoryCode @relation(fields: [categoryCodeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryCodeId])
  @@index([categoryCodeId])
}
